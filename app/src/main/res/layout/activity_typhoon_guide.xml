<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="false"
    tools:context=".TyphoonGuideActivity">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@drawable/slide1" />

        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#66FFFFFF" />

        <RelativeLayout
            android:id="@+id/stickyHeader"
            android:layout_width="match_parent"
            android:layout_height="140dp"
            android:layout_alignParentTop="true"
            android:background="@drawable/bg_header_dashboard"
            android:paddingTop="20dp"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:elevation="8dp">

            <ImageView
                android:id="@+id/menuIcon"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:layout_centerVertical="true"
                android:src="@drawable/ic_menu"
                app:tint="@android:color/white" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_toEndOf="@id/menuIcon"
                android:layout_centerVertical="true"
                android:layout_marginStart="16dp"
                android:text="Disaster\nGuides"
                android:textColor="@android:color/white"
                android:textSize="22sp"
                android:textStyle="bold"
                android:lineSpacingExtra="2dp" />

            <ImageView
                android:layout_width="160dp"
                android:layout_height="90dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:scaleType="centerCrop"
                android:src="@drawable/kandili" />
        </RelativeLayout>

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_below="@+id/stickyHeader"
            android:clipToPadding="false"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingBottom="40dp">

                <Space android:layout_width="match_parent" android:layout_height="24dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_disaster_container"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_disaster_title"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="14dp">
                        <ImageView android:layout_width="42dp" android:layout_height="42dp" android:src="@drawable/ic_typhoon" app:tint="@android:color/white" />
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="14dp" android:layout_weight="1" android:text="TYPHOON\nPROTOCOLS" android:textColor="@android:color/white" android:textSize="23sp" android:textStyle="bold" />
                        <ImageView android:id="@+id/ic_arrow_back" android:layout_width="34dp" android:layout_height="34dp" android:src="@drawable/ic_arrow_back" app:tint="@android:color/white" />
                    </LinearLayout>

                    <Space android:layout_width="match_parent" android:layout_height="22dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_typhoon_content_card"
                        android:orientation="vertical"
                        android:padding="18dp"
                        android:layout_marginBottom="16dp">

                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="BEFORE" android:textColor="@android:color/white" android:textSize="22sp" android:textStyle="bold" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Risk Mitigation &amp; Planning" android:textColor="#F0E3E3" android:textSize="12sp" />
                        <Space android:layout_width="match_parent" android:layout_height="14dp" />
                        <FrameLayout android:layout_width="match_parent" android:layout_height="130dp" android:background="@drawable/bg_typhoon_inner_image" android:clipToOutline="true">
                            <ImageView android:layout_width="match_parent" android:layout_height="match_parent" android:scaleType="centerCrop" android:src="@drawable/typhoon_before" />
                        </FrameLayout>
                        <Space android:layout_width="match_parent" android:layout_height="16dp" />

                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="• Critical Logistics" android:textColor="@android:color/white" android:textSize="16sp" android:textStyle="bold" />
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp" android:text="Establish a 72-hour survival kit including potable water, non-perishable rations, and medical supplies. Secure all identification documents in waterproof casing." android:textColor="#DFDFDF" android:textSize="13sp" />

                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="• Structural Defense" android:textColor="@android:color/white" android:textSize="16sp" android:textStyle="bold" />
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp" android:text="Inspect structural integrity of roofs and windows. Prune vegetation near power lines and secure outdoor objects that could become high-velocity projectiles." android:textColor="#DFDFDF" android:textSize="13sp" />

                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="• Evacuation Readiness" android:textColor="@android:color/white" android:textSize="16sp" android:textStyle="bold" />
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp" android:text="Identify the nearest designated CDRRMO evacuation centers and map out primary and secondary safe routes. Keep vehicles fully fueled and parked on elevated ground." android:textColor="#DFDFDF" android:textSize="13sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_typhoon_content_card"
                        android:orientation="vertical"
                        android:padding="18dp"
                        android:layout_marginBottom="16dp">

                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="DURING" android:textColor="@android:color/white" android:textSize="22sp" android:textStyle="bold" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Emergency Response" android:textColor="#F0E3E3" android:textSize="12sp" />
                        <Space android:layout_width="match_parent" android:layout_height="14dp" />
                        <FrameLayout android:layout_width="match_parent" android:layout_height="130dp" android:background="@drawable/bg_typhoon_inner_image" android:clipToOutline="true">
                            <ImageView android:layout_width="match_parent" android:layout_height="match_parent" android:scaleType="centerCrop" android:src="@drawable/typhoon_guide" />
                        </FrameLayout>
                        <Space android:layout_width="match_parent" android:layout_height="16dp" />

                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="• Situational Containment" android:textColor="@android:color/white" android:textSize="16sp" android:textStyle="bold" />
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp" android:text="Maintain total indoor stay. Do not attempt to traverse flooded areas or move during the eye of the storm. Disconnect main electrical breakers if water ingress is detected." android:textColor="#DFDFDF" android:textSize="13sp" />

                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="• Communication Protocols" android:textColor="@android:color/white" android:textSize="16sp" android:textStyle="bold" />
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp" android:text="Minimize mobile usage to conserve battery for emergency calls. Monitor local frequencies and CDRRMO updates for real-time evacuation orders." android:textColor="#DFDFDF" android:textSize="13sp" />

                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="• Health &amp; Safety" android:textColor="@android:color/white" android:textSize="16sp" android:textStyle="bold" />
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp" android:text="Keep emergency medical kits within immediate reach. If structural damage occurs, take cover under sturdy furniture and protect your head from falling debris." android:textColor="#DFDFDF" android:textSize="13sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_typhoon_content_card"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="AFTER" android:textColor="@android:color/white" android:textSize="22sp" android:textStyle="bold" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Recovery &amp; Assessment" android:textColor="#F0E3E3" android:textSize="12sp" />
                        <Space android:layout_width="match_parent" android:layout_height="14dp" />
                        <FrameLayout android:layout_width="match_parent" android:layout_height="130dp" android:background="@drawable/bg_typhoon_inner_image" android:clipToOutline="true">
                            <ImageView android:layout_width="match_parent" android:layout_height="match_parent" android:scaleType="centerCrop" android:src="@drawable/slide4" />
                        </FrameLayout>
                        <Space android:layout_width="match_parent" android:layout_height="16dp" />

                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="• Damage Assessment" android:textColor="@android:color/white" android:textSize="16sp" android:textStyle="bold" />
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp" android:text="Verify structural safety and check for gas leaks or exposed wiring before entering premises. Boil all water sources for 10 minutes prior to consumption." android:textColor="#DFDFDF" android:textSize="13sp" />

                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="• Community Coordination" android:textColor="@android:color/white" android:textSize="16sp" android:textStyle="bold" />
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp" android:text="Clear drainage of debris to prevent secondary flooding. Report casualties or major infrastructure damage to the local barangay command center immediately." android:textColor="#DFDFDF" android:textSize="13sp" />

                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="• Hazard Awareness" android:textColor="@android:color/white" android:textSize="16sp" android:textStyle="bold" />
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp" android:text="Strictly avoid wading through floodwaters to prevent leptospirosis and electrocution from submerged power lines. Document property damage for assistance claims." android:textColor="#DFDFDF" android:textSize="13sp" />
                    </LinearLayout>

                    <Space android:layout_width="match_parent" android:layout_height="24dp" />
                    <View android:layout_width="match_parent" android:layout_height="54dp" android:background="@drawable/bg_typhoon_bottom_bar" />
                </LinearLayout>
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

    </RelativeLayout>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/nav_view"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="#181818"
        app:headerLayout="@layout/nav_header"
        app:menu="@menu/nav_menu"
        app:itemIconTint="@android:color/white"
        app:itemTextColor="@android:color/white"
        app:itemIconSize="28dp"
        app:itemIconPadding="24dp"
        app:itemTextAppearance="@style/NavMenuItemStyle"
        app:itemShapeInsetStart="0dp"
        app:itemShapeInsetEnd="0dp"
        app:itemHorizontalPadding="24dp"
        app:itemVerticalPadding="20dp"
        app:itemBackground="@drawable/nav_item_selector" />

</androidx.drawerlayout.widget.DrawerLayout>