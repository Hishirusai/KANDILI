<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="false"
    tools:context=".FloodGuideActivity">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@drawable/slide1" />

        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#66FFFFFF" />

        <RelativeLayout
            android:id="@+id/stickyHeader"
            android:layout_width="match_parent"
            android:layout_height="140dp"
            android:layout_alignParentTop="true"
            android:background="@drawable/bg_header_dashboard"
            android:paddingTop="20dp"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:elevation="8dp">

            <ImageView
                android:id="@+id/menuIcon"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:layout_centerVertical="true"
                android:src="@drawable/ic_menu"
                app:tint="@android:color/white" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_toEndOf="@id/menuIcon"
                android:layout_centerVertical="true"
                android:layout_marginStart="16dp"
                android:text="Disaster\nGuides"
                android:textColor="@android:color/white"
                android:textSize="22sp"
                android:textStyle="bold"
                android:lineSpacingExtra="2dp" />

            <ImageView
                android:layout_width="160dp"
                android:layout_height="90dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:scaleType="centerCrop"
                android:src="@drawable/kandili" />
        </RelativeLayout>

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_below="@+id/stickyHeader"
            android:clipToPadding="false"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingBottom="40dp">

                <Space android:layout_width="match_parent" android:layout_height="24dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_disaster_container"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_disaster_title"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="14dp">

                        <ImageView
                            android:layout_width="42dp"
                            android:layout_height="42dp"
                            android:src="@drawable/ic_flood"
                            app:tint="@android:color/white" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="14dp"
                            android:layout_weight="1"
                            android:text="FLOOD\nPROTOCOLS"
                            android:textColor="@android:color/white"
                            android:textSize="23sp"
                            android:textStyle="bold" />

                        <ImageView
                            android:id="@+id/ic_arrow_back"
                            android:layout_width="34dp"
                            android:layout_height="34dp"
                            android:src="@drawable/ic_arrow_back"
                            app:tint="@android:color/white" />
                    </LinearLayout>

                    <Space android:layout_width="match_parent" android:layout_height="22dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_typhoon_content_card"
                        android:orientation="vertical"
                        android:padding="18dp"
                        android:layout_marginBottom="16dp">

                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="BEFORE" android:textColor="@android:color/white" android:textSize="22sp" android:textStyle="bold" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Risk Mitigation &amp; Planning" android:textColor="#F0E3E3" android:textSize="12sp" />
                        <Space android:layout_width="match_parent" android:layout_height="14dp" />
                        <FrameLayout android:layout_width="match_parent" android:layout_height="130dp" android:background="@drawable/bg_typhoon_inner_image" android:clipToOutline="true">
                            <ImageView android:layout_width="match_parent" android:layout_height="match_parent" android:scaleType="centerCrop" android:src="@drawable/flood_guide" />
                        </FrameLayout>
                        <Space android:layout_width="match_parent" android:layout_height="16dp" />

                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="• Asset Protection" android:textColor="@android:color/white" android:textSize="16sp" android:textStyle="bold" />
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp" android:text="Elevate critical appliances, furniture, and electrical panels above potential flood levels. Move highly valuable items and documents to the highest floor." android:textColor="#DFDFDF" android:textSize="13sp" />

                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="• Infrastructure Prep" android:textColor="@android:color/white" android:textSize="16sp" android:textStyle="bold" />
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp" android:text="Clear street drains and gutters to allow maximum water flow. Install check valves in plumbing to prevent floodwater from backing up into the drains." android:textColor="#DFDFDF" android:textSize="13sp" />

                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="• Evacuation Readiness" android:textColor="@android:color/white" android:textSize="16sp" android:textStyle="bold" />
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp" android:text="Familiarize yourself with local flood hazard maps. Pack a watertight Go-Bag and plan an evacuation route that avoids low-lying areas." android:textColor="#DFDFDF" android:textSize="13sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_typhoon_content_card"
                        android:orientation="vertical"
                        android:padding="18dp"
                        android:layout_marginBottom="16dp">

                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="DURING" android:textColor="@android:color/white" android:textSize="22sp" android:textStyle="bold" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Emergency Response" android:textColor="#F0E3E3" android:textSize="12sp" />
                        <Space android:layout_width="match_parent" android:layout_height="14dp" />
                        <FrameLayout android:layout_width="match_parent" android:layout_height="130dp" android:background="@drawable/bg_typhoon_inner_image" android:clipToOutline="true">
                            <ImageView android:layout_width="match_parent" android:layout_height="match_parent" android:scaleType="centerCrop" android:src="@drawable/slide1" />
                        </FrameLayout>
                        <Space android:layout_width="match_parent" android:layout_height="16dp" />

                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="• Water Avoidance" android:textColor="@android:color/white" android:textSize="16sp" android:textStyle="bold" />
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp" android:text="Never walk, swim, or drive through floodwaters. Just 6 inches of moving water can knock you down, and 12 inches can sweep away a vehicle." android:textColor="#DFDFDF" android:textSize="13sp" />

                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="• Structural Safety" android:textColor="@android:color/white" android:textSize="16sp" android:textStyle="bold" />
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp" android:text="If water enters your home, turn off the main power breaker immediately to avoid electrocution. Move to the highest level of the building." android:textColor="#DFDFDF" android:textSize="13sp" />

                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="• Trapped Scenarios" android:textColor="@android:color/white" android:textSize="16sp" android:textStyle="bold" />
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp" android:text="If trapped in a building, get to the roof. Do not climb into a closed attic where you could become trapped by rising water. Signal for rescue." android:textColor="#DFDFDF" android:textSize="13sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_typhoon_content_card"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="AFTER" android:textColor="@android:color/white" android:textSize="22sp" android:textStyle="bold" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Recovery &amp; Assessment" android:textColor="#F0E3E3" android:textSize="12sp" />
                        <Space android:layout_width="match_parent" android:layout_height="14dp" />
                        <FrameLayout android:layout_width="match_parent" android:layout_height="130dp" android:background="@drawable/bg_typhoon_inner_image" android:clipToOutline="true">
                            <ImageView android:layout_width="match_parent" android:layout_height="match_parent" android:scaleType="centerCrop" android:src="@drawable/slide4" />
                        </FrameLayout>
                        <Space android:layout_width="match_parent" android:layout_height="16dp" />

                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="• Hazard Awareness" android:textColor="@android:color/white" android:textSize="16sp" android:textStyle="bold" />
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp" android:text="Do not return home until authorities declare it safe. Be extremely cautious of submerged debris, hidden drop-offs, and displaced wildlife/snakes." android:textColor="#DFDFDF" android:textSize="13sp" />

                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="• Contamination Protocol" android:textColor="@android:color/white" android:textSize="16sp" android:textStyle="bold" />
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp" android:text="Consider all floodwater highly contaminated. Discard any food or medicine that came into contact with it. Thoroughly disinfect all flooded surfaces." android:textColor="#DFDFDF" android:textSize="13sp" />

                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="• Structural Inspection" android:textColor="@android:color/white" android:textSize="16sp" android:textStyle="bold" />
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp" android:text="Have a qualified electrician check the electrical system before turning the power back on. Take photos of property damage for insurance or assistance claims." android:textColor="#DFDFDF" android:textSize="13sp" />
                    </LinearLayout>

                    <Space android:layout_width="match_parent" android:layout_height="24dp" />
                    <View android:layout_width="match_parent" android:layout_height="54dp" android:background="@drawable/bg_typhoon_bottom_bar" />
                </LinearLayout>
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

    </RelativeLayout>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/nav_view"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="#181818"
        app:headerLayout="@layout/nav_header"
        app:menu="@menu/nav_menu"
        app:itemIconTint="@android:color/white"
        app:itemTextColor="@android:color/white"
        app:itemIconSize="28dp"
        app:itemIconPadding="24dp"
        app:itemTextAppearance="@style/NavMenuItemStyle"
        app:itemBackground="@drawable/nav_item_selector" />

</androidx.drawerlayout.widget.DrawerLayout>