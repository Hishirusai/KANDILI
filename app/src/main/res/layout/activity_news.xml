<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".NewsActivity">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/slide1"
            android:scaleType="centerCrop" />

        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#66FFFFFF" />

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="140dp"
                    android:background="@drawable/bg_header_dashboard"
                    android:paddingTop="20dp"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp">

                    <ImageView
                        android:id="@+id/menuIcon"
                        android:layout_width="34dp"
                        android:layout_height="34dp"
                        android:layout_centerVertical="true"
                        android:src="@drawable/ic_menu"
                        app:tint="@android:color/white" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_toEndOf="@id/menuIcon"
                        android:layout_centerVertical="true"
                        android:layout_marginStart="16dp"
                        android:text="News"
                        android:textColor="@android:color/white"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <ImageView
                        android:layout_width="160dp"
                        android:layout_height="90dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:scaleType="centerCrop"
                        android:src="@drawable/kandili" />
                </RelativeLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingBottom="24dp">

                    <Space
                        android:layout_width="match_parent"
                        android:layout_height="12dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_news_container"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            android:background="@drawable/bg_news_card_outer"
                            android:orientation="vertical">

                            <FrameLayout
                                android:layout_width="match_parent"
                                android:layout_height="220dp">
                                <ImageView android:layout_width="match_parent" android:layout_height="match_parent" android:src="@drawable/news1" android:scaleType="centerCrop" />
                                <View android:layout_width="match_parent" android:layout_height="35dp" android:layout_gravity="top" android:rotation="180" android:background="@drawable/bg_news_image_fade" />
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="top|center_horizontal" android:layout_marginTop="12dp" android:text="APRIL 21, 2026" android:textColor="@android:color/white" android:textSize="13sp" android:textStyle="bold" />
                            </FrameLayout>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:background="@drawable/bg_news_text_section"
                                android:orientation="vertical"
                                android:padding="18dp"
                                android:gravity="center">
                                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="&quot;The Zamboanga City Water District (ZCWD) has strengthened its water conservation measures as demand increases amid recent high heat index levels of 40 to 42 degrees Celsius, according to state weather agency&quot;" android:textAlignment="center" android:textColor="@android:color/white" android:textSize="14sp" />
                                <androidx.appcompat.widget.AppCompatButton android:id="@+id/btnViewMore1" android:layout_width="230dp" android:layout_height="44dp" android:layout_marginTop="16dp" android:background="@drawable/bg_view_more" android:text="VIEW MORE" android:textAllCaps="false" android:textColor="@android:color/white" android:textStyle="bold" />
                            </LinearLayout>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            android:background="@drawable/bg_news_card_outer"
                            android:orientation="vertical">

                            <FrameLayout
                                android:layout_width="match_parent"
                                android:layout_height="220dp">
                                <ImageView android:layout_width="match_parent" android:layout_height="match_parent" android:src="@drawable/news2" android:scaleType="centerCrop" />
                                <View android:layout_width="match_parent" android:layout_height="35dp" android:layout_gravity="top" android:rotation="180" android:background="@drawable/bg_news_image_fade" />
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="top|center_horizontal" android:layout_marginTop="12dp" android:text="FEBRUARY 15, 2026" android:textColor="@android:color/white" android:textSize="13sp" android:textStyle="bold" />
                            </FrameLayout>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:background="@drawable/bg_news_text_section"
                                android:orientation="vertical"
                                android:padding="18dp"
                                android:gravity="center">
                                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="&quot;Landslide reported in the Abong abong district near the A4 highway. Road is closed until further notice. Seek alternative routes.&quot;" android:textAlignment="center" android:textColor="@android:color/white" android:textSize="14sp" />
                                <androidx.appcompat.widget.AppCompatButton android:layout_width="230dp" android:layout_height="44dp" android:layout_marginTop="16dp" android:background="@drawable/bg_view_more" android:text="VIEW MORE" android:textAllCaps="false" android:textColor="@android:color/white" android:textStyle="bold" />
                            </LinearLayout>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_news_card_outer"
                            android:orientation="vertical">

                            <FrameLayout
                                android:layout_width="match_parent"
                                android:layout_height="220dp">
                                <ImageView android:layout_width="match_parent" android:layout_height="match_parent" android:src="@drawable/news3" android:scaleType="centerCrop" />
                                <View android:layout_width="match_parent" android:layout_height="35dp" android:layout_gravity="top" android:rotation="180" android:background="@drawable/bg_news_image_fade" />
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="top|center_horizontal" android:layout_marginTop="12dp" android:text="FEBRUARY 22, 2026" android:textColor="@android:color/white" android:textSize="13sp" android:textStyle="bold" />
                            </FrameLayout>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:background="@drawable/bg_news_text_section"
                                android:orientation="vertical"
                                android:padding="18dp"
                                android:gravity="center">
                                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="&quot;Flash flood warning issued for the Cawa-cawa. Heavy rainfall is expected in the next 24 hours. Stay tuned for further updates.&quot;" android:textAlignment="center" android:textColor="@android:color/white" android:textSize="14sp" />
                                <androidx.appcompat.widget.AppCompatButton android:layout_width="230dp" android:layout_height="44dp" android:layout_marginTop="16dp" android:background="@drawable/bg_view_more" android:text="VIEW MORE" android:textAllCaps="false" android:textColor="@android:color/white" android:textStyle="bold" />
                            </LinearLayout>
                        </LinearLayout>

                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </FrameLayout>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/nav_view"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="#181818"
        app:headerLayout="@layout/nav_header"
        app:menu="@menu/nav_menu"
        app:itemIconTint="@android:color/white"
        app:itemTextColor="@android:color/white"
        app:itemIconSize="28dp"
        app:itemIconPadding="24dp"
        app:itemTextAppearance="@style/NavMenuItemStyle"
        app:itemShapeInsetStart="0dp"
        app:itemShapeInsetEnd="0dp"
        app:itemHorizontalPadding="24dp"
        app:itemVerticalPadding="20dp"
        app:itemBackground="@drawable/nav_item_selector" />

</androidx.drawerlayout.widget.DrawerLayout>