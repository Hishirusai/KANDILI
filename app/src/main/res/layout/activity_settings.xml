<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".SettingsActivity">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@drawable/slide1" />

        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#66FFFFFF" />

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="24dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="140dp"
                    android:background="@drawable/bg_header_dashboard"
                    android:paddingTop="20dp"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp">

                    <ImageView
                        android:id="@+id/menuIcon"
                        android:layout_width="34dp"
                        android:layout_height="34dp"
                        android:layout_centerVertical="true"
                        android:src="@drawable/ic_menu"
                        app:tint="@android:color/white" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_toEndOf="@id/menuIcon"
                        android:layout_centerVertical="true"
                        android:layout_marginStart="16dp"
                        android:text="Settings"
                        android:textColor="@android:color/white"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <ImageView
                        android:layout_width="160dp"
                        android:layout_height="90dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:scaleType="centerCrop"
                        android:src="@drawable/kandili" />
                </RelativeLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp">

                    <Space
                        android:layout_width="match_parent"
                        android:layout_height="24dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_settings_container"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_settings_title"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingStart="18dp"
                            android:paddingTop="16dp"
                            android:paddingEnd="18dp"
                            android:paddingBottom="16dp">

                            <ImageView
                                android:layout_width="46dp"
                                android:layout_height="46dp"
                                android:src="@drawable/ic_settings_outline"
                                app:tint="@android:color/white" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="14dp"
                                android:lineSpacingExtra="2dp"
                                android:text="PROFILE\nSETTINGS"
                                android:textColor="@android:color/white"
                                android:textSize="24sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <Space
                            android:layout_width="match_parent"
                            android:layout_height="16dp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:background="@drawable/bg_settings_option"
                            android:gravity="center"
                            android:text="View Personal Details"
                            android:textColor="#333333"
                            android:textSize="18sp" />

                        <Space
                            android:layout_width="match_parent"
                            android:layout_height="14dp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:background="@drawable/bg_settings_option"
                            android:gravity="center"
                            android:text="Update Email Address"
                            android:textColor="#333333"
                            android:textSize="18sp" />

                        <Space
                            android:layout_width="match_parent"
                            android:layout_height="14dp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:background="@drawable/bg_settings_option"
                            android:gravity="center"
                            android:text="Change Password"
                            android:textColor="#333333"
                            android:textSize="18sp" />

                        <Space
                            android:layout_width="match_parent"
                            android:layout_height="14dp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:background="@drawable/bg_settings_option"
                            android:gravity="center"
                            android:text="Delete Account"
                            android:textColor="#333333"
                            android:textSize="18sp" />
                    </LinearLayout>

                    <Space
                        android:layout_width="match_parent"
                        android:layout_height="18dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_settings_container"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_settings_section_bar"
                            android:gravity="center"
                            android:text="ACCESSIBILITY"
                            android:textColor="@android:color/white"
                            android:textSize="22sp"
                            android:textStyle="bold" />

                        <Space
                            android:layout_width="match_parent"
                            android:layout_height="16dp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:background="@drawable/bg_settings_option"
                            android:gravity="center"
                            android:text="Switch to Dark Mode"
                            android:textColor="#333333"
                            android:textSize="18sp" />

                        <Space
                            android:layout_width="match_parent"
                            android:layout_height="14dp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:background="@drawable/bg_settings_option"
                            android:gravity="center"
                            android:text="Change App Language"
                            android:textColor="#333333"
                            android:textSize="18sp" />

                        <Space
                            android:layout_width="match_parent"
                            android:layout_height="14dp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:background="@drawable/bg_settings_option"
                            android:gravity="center"
                            android:text="Color Correction"
                            android:textColor="#333333"
                            android:textSize="18sp" />

                        <Space
                            android:layout_width="match_parent"
                            android:layout_height="26dp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_settings_section_bar"
                            android:gravity="center"
                            android:text="HELP"
                            android:textColor="@android:color/white"
                            android:textSize="22sp"
                            android:textStyle="bold" />

                        <Space
                            android:layout_width="match_parent"
                            android:layout_height="16dp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:background="@drawable/bg_settings_option"
                            android:gravity="center"
                            android:text="Kandili FAQ"
                            android:textColor="#333333"
                            android:textSize="18sp" />

                        <Space
                            android:layout_width="match_parent"
                            android:layout_height="14dp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:background="@drawable/bg_settings_option"
                            android:gravity="center"
                            android:text="Privacy Policy"
                            android:textColor="#333333"
                            android:textSize="18sp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </FrameLayout>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/nav_view"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="#181818"
        app:headerLayout="@layout/nav_header"
        app:menu="@menu/nav_menu"
        app:itemIconTint="@android:color/white"
        app:itemTextColor="@android:color/white"
        app:itemIconSize="28dp"
        app:itemIconPadding="24dp"
        app:itemTextAppearance="@style/NavMenuItemStyle"
        app:itemShapeInsetStart="0dp"
        app:itemShapeInsetEnd="0dp"
        app:itemHorizontalPadding="24dp"
        app:itemVerticalPadding="20dp"
        app:itemBackground="@drawable/nav_item_selector" />

</androidx.drawerlayout.widget.DrawerLayout>