<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="false"
    tools:context=".HotlinesActivity">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/slide1"
            android:scaleType="centerCrop" />

        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#66FFFFFF" />

        <RelativeLayout
            android:id="@+id/stickyHeader"
            android:layout_width="match_parent"
            android:layout_height="140dp"
            android:layout_alignParentTop="true"
            android:background="@drawable/bg_header_dashboard"
            android:paddingTop="20dp"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:elevation="8dp">

            <ImageView
                android:id="@+id/menuIcon"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:layout_centerVertical="true"
                android:src="@drawable/ic_menu"
                app:tint="@android:color/white" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_toEndOf="@id/menuIcon"
                android:layout_centerVertical="true"
                android:layout_marginStart="16dp"
                android:text="Disaster\nGuides"
                android:textColor="@android:color/white"
                android:textSize="22sp"
                android:textStyle="bold"
                android:lineSpacingExtra="2dp" />

            <ImageView
                android:layout_width="160dp"
                android:layout_height="90dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:scaleType="centerCrop"
                android:src="@drawable/kandili" />
        </RelativeLayout>

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_below="@+id/stickyHeader"
            android:fillViewport="true"
            android:clipToPadding="false">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingBottom="24dp">

                <Space
                    android:layout_width="match_parent"
                    android:layout_height="22dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_hotlines_container"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_hotlines_title"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="16dp">

                        <ImageView
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:src="@drawable/ic_call_outline"
                            app:tint="@android:color/white" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="14dp"
                            android:text="EMERGENCY\nHOTLINES"
                            android:textColor="@android:color/white"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:lineSpacingExtra="2dp" />
                    </LinearLayout>

                    <Space android:layout_width="match_parent" android:layout_height="14dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">
                        <ImageView
                            android:id="@+id/barangayMenuIcon"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:src="@drawable/ic_menu"
                            app:tint="@android:color/white" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="10dp" android:text="Barangay:" android:textColor="@android:color/white" android:textSize="20sp" android:textStyle="bold" />
                        <TextView
                            android:id="@+id/tvBarangayName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:text="San Roque"
                            android:textColor="@android:color/white"
                            android:textSize="20sp" />
                    </LinearLayout>

                    <Space android:layout_width="match_parent" android:layout_height="12dp" />

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp" android:background="@drawable/bg_hotline_row" android:gravity="center_vertical" android:minHeight="54dp" android:padding="10dp" android:paddingStart="22dp">
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Assistance" android:textColor="#222222" android:textSize="18sp" />
                            <TextView android:id="@+id/tvBarangayAssistance" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0917-111-0001" android:textColor="#244BFF" android:textSize="18sp" android:textStyle="bold" />
                        </LinearLayout>

                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/bg_hotline_row" android:gravity="center_vertical" android:minHeight="54dp" android:padding="10dp" android:paddingStart="22dp">
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Help Desk" android:textColor="#222222" android:textSize="18sp" />
                            <TextView android:id="@+id/tvBarangayHelpDesk" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0919-111-0002" android:textColor="#244BFF" android:textSize="18sp" android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="8dp" android:layout_marginTop="16dp" android:layout_marginBottom="16dp" android:background="@drawable/bg_hotlines_divider" />

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Patrol 117" android:textColor="@android:color/white" android:textSize="20sp" android:textStyle="bold" />
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:background="@drawable/bg_hotline_row" android:gravity="center" android:minHeight="54dp" android:padding="10dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="117 / 911" android:textColor="#244BFF" android:textSize="18sp" android:textStyle="bold" />
                    </LinearLayout>

                    <Space android:layout_width="match_parent" android:layout_height="14dp" />

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="ZCDRRMO" android:textColor="@android:color/white" android:textSize="20sp" android:textStyle="bold" />
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:background="@drawable/bg_hotline_row" android:gravity="center" android:minHeight="54dp" android:padding="10dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0966-731-6242" android:textColor="#244BFF" android:textSize="18sp" android:textStyle="bold" />
                    </LinearLayout>

                    <Space android:layout_width="match_parent" android:layout_height="14dp" />

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center_horizontal" android:text="Philippine Coast Guard" android:textColor="@android:color/white" android:textSize="20sp" android:textStyle="bold" />
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:background="@drawable/bg_hotline_row" android:gravity="center_vertical" android:minHeight="64dp" android:padding="10dp" android:paddingStart="22dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="Rescue Team" android:textColor="#111111" android:textSize="18sp" android:textStyle="bold" />
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="end">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0969-467-3621" android:textColor="#244BFF" android:textSize="16sp" android:textStyle="bold" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0967-276-1478" android:textColor="#244BFF" android:textSize="16sp" android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="8dp" android:layout_marginTop="16dp" android:layout_marginBottom="16dp" android:background="@drawable/bg_hotlines_divider" />

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginEnd="10dp" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center_horizontal" android:text="Hospitals" android:textColor="@android:color/white" android:textSize="20sp" android:textStyle="bold" />
                            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="14dp" android:background="@drawable/bg_hotline_row" android:gravity="center_vertical" android:minHeight="54dp" android:padding="10dp">
                                <ImageView android:layout_width="32dp" android:layout_height="32dp" android:src="@drawable/hospital_logo1" android:scaleType="fitCenter" />
                                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="end" android:text="0917-000-1111" android:textColor="#244BFF" android:textSize="14sp" android:textStyle="bold" />
                            </LinearLayout>
                            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:background="@drawable/bg_hotline_row" android:gravity="center_vertical" android:minHeight="54dp" android:padding="10dp">
                                <ImageView android:layout_width="32dp" android:layout_height="32dp" android:src="@drawable/hospital_logo2" android:scaleType="fitCenter" />
                                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="end" android:text="0919-000-2222" android:textColor="#244BFF" android:textSize="14sp" android:textStyle="bold" />
                            </LinearLayout>
                        </LinearLayout>

                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="10dp" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center_horizontal" android:text="Ambulances" android:textColor="@android:color/white" android:textSize="20sp" android:textStyle="bold" />
                            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="14dp" android:background="@drawable/bg_hotline_row" android:gravity="center" android:minHeight="54dp" android:padding="10dp">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0918-222-3333" android:textColor="#244BFF" android:textSize="14sp" android:textStyle="bold" />
                            </LinearLayout>
                            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:background="@drawable/bg_hotline_row" android:gravity="center" android:minHeight="54dp" android:padding="10dp">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0917-444-5555" android:textColor="#244BFF" android:textSize="14sp" android:textStyle="bold" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="8dp" android:layout_marginTop="16dp" android:layout_marginBottom="16dp" android:background="@drawable/bg_hotlines_divider" />

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginEnd="10dp" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center_horizontal" android:text="Fire Station" android:textColor="@android:color/white" android:textSize="20sp" android:textStyle="bold" />
                            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="14dp" android:background="@drawable/bg_hotline_row" android:gravity="center" android:minHeight="54dp" android:padding="10dp">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0955-781-6063" android:textColor="#244BFF" android:textSize="14sp" android:textStyle="bold" />
                            </LinearLayout>
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="10dp" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center_horizontal" android:text="Police" android:textColor="@android:color/white" android:textSize="20sp" android:textStyle="bold" />
                            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="14dp" android:background="@drawable/bg_hotline_row" android:gravity="center" android:minHeight="54dp" android:padding="10dp">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0917-710-2323" android:textColor="#244BFF" android:textSize="14sp" android:textStyle="bold" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </RelativeLayout>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/nav_view"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="#181818"
        app:headerLayout="@layout/nav_header"
        app:menu="@menu/nav_menu"
        app:itemIconTint="@android:color/white"
        app:itemTextColor="@android:color/white"
        app:itemIconSize="28dp"
        app:itemIconPadding="24dp"
        app:itemTextAppearance="@style/NavMenuItemStyle"
        app:itemHorizontalPadding="24dp"
        app:itemVerticalPadding="20dp"
        app:itemBackground="@drawable/nav_item_selector" />

</androidx.drawerlayout.widget.DrawerLayout>